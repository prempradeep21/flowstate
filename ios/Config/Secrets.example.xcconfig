// Copy this file to Config/Secrets.xcconfig (git-ignored) and fill in real values.
// These mirror the web app's NEXT_PUBLIC_SUPABASE_* env vars.

// Supabase project URL, e.g. https://abcdefgh.supabase.co
// NOTE: xcconfig treats // as a comment even inside values, so escape the
// scheme slashes as shown: https:/​/ -> write the host without scheme here and
// the app prepends https. Simplest: store only the host.
SUPABASE_HOST = YOUR_PROJECT.supabase.co

// Supabase anon (publishable) key.
SUPABASE_ANON_KEY = YOUR_ANON_KEY

// Base URL of the deployed web app, used by the WKWebView artifact viewer.
// Store host only (app prepends https).
WEB_HOST = your-flowstate-web.vercel.app

// OAuth redirect scheme registered below in Info.plist (CFBundleURLSchemes).
OAUTH_REDIRECT_SCHEME = flowstate
