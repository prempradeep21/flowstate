<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleName</key>
	<string>Flowstate</string>
	<key>CFBundleDisplayName</key>
	<string>Flowstate</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- Allow http to the local dev server (WEB_HOST=localhost:PORT) for the
	     WebView artifact renderer during development/demo. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<!-- Allow landscape so wide artifacts (tables, calendars) can be viewed in
	     a horizontal format that fills the screen. The web renderer's
	     fit-to-viewport logic re-fits on orientation change. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- Injected from Secrets.xcconfig -->
	<key>SUPABASE_HOST</key>
	<string>$(SUPABASE_HOST)</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>WEB_HOST</key>
	<string>$(WEB_HOST)</string>
	<key>OAUTH_REDIRECT_SCHEME</key>
	<string>$(OAUTH_REDIRECT_SCHEME)</string>
	<!-- NOTE: the flowstate:// scheme is intentionally NOT registered in
	     CFBundleURLTypes. ASWebAuthenticationSession captures the OAuth callback
	     via its own private callbackURLScheme channel; registering it here makes
	     iOS hijack the redirect into onOpenURL, which breaks the PKCE exchange. -->
</dict>
</plist>
