{
  "name": "flowstate",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "engines": {
    "node": ">=20.4.0"
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "electron:dev": "ELECTRON_DEV=1 concurrently -k -n next,electron \"next dev -p 3000\" \"wait-on http://localhost:3000 && env -u ELECTRON_RUN_AS_NODE electron electron/main.js\"",
    "prepare:standalone": "node scripts/prepare-standalone.js",
    "dist:mac": "NEXT_PUBLIC_IS_DESKTOP=true next build && npm run prepare:standalone && electron-builder --mac",
    "dev:showcase": "node scripts/showcase-dev.js",
    "dev:spec": "node scripts/spec-viewer-dev.js",
    "dev:repo-explorer": "node scripts/repo-explorer-dev.js",
    "dev:skill-viewer": "node scripts/skill-viewer-dev.js",
    "dev:artifact-catalog": "node scripts/artifact-catalog-dev.js",
    "dev:design-system": "node scripts/design-system-dev.js",
    "dev:mobile-sdlc-sandbox": "node scripts/mobile-sdlc-sandbox-dev.js",
    "dev:ui-instructions": "node scripts/ui-instructions-viewer-dev.js",
    "dev:ploy-landing": "node scripts/ploy-landing-dev.js",
    "ploy-landing:mirror": "node scripts/mirror-ploy-landing.js",
    "ui-instructions:compile": "node scripts/extract-ui-instructions.js && node scripts/compile-ui-instructions-md.js",
    "chronology:sync": "node scripts/generate-chronology.js --sync",
    "dev:clean": "node scripts/clean-dev.js",
    "build": "next build",
    "export:design-tokens": "node scripts/export-design-tokens.mjs",
    "export:design-system": "node scripts/export-design-system.mjs",
    "start": "next start",
    "lint": "next lint",
    "supabase:check-env": "node scripts/check-supabase-env.js",
    "supabase:migrations": "node scripts/print-supabase-migrations.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "benchmark:pan-zoom": "node scripts/benchmark-pan-zoom.mjs",
    "perf": "node scripts/perf/run-benchmark.mjs",
    "perf:electron": "node scripts/perf/run-benchmark.mjs --electron"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@cursor/sdk": "^1.0.18",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.1",
    "@visx/axis": "^3.12.0",
    "@visx/curve": "^3.12.0",
    "@visx/grid": "^3.12.0",
    "@visx/group": "^3.12.0",
    "@visx/responsive": "^3.12.0",
    "@visx/scale": "^3.12.0",
    "@visx/shape": "^3.12.0",
    "@visx/tooltip": "^3.12.0",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "framer-motion": "^12.40.0",
    "googleapis": "^173.0.0",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "leaflet": "^1.9.4",
    "lenis": "^1.3.25",
    "lucide-react": "^1.23.0",
    "mammoth": "^1.12.0",
    "marked": "^15.0.7",
    "next": "15.5.18",
    "openai": "^6.42.0",
    "particles.js": "^2.0.0",
    "rbush": "^4.0.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "seslen": "^0.1.0",
    "simple-icons": "^16.24.1",
    "simplex-noise": "^4.0.3",
    "three": "^0.184.0",
    "xlsx": "^0.18.5",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.6.2",
    "@types/rbush": "^4.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "playwright": "^1.61.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  }
}
