{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-artifact-catalog/types/**/*.ts",
    ".next-build-check/types/**/*.ts",
    ".next-design-system/types/**/*.ts",
    ".next-mobile-sdlc-sandbox/types/**/*.ts",
    ".next-repo-explorer/types/**/*.ts",
    ".next-showcase/types/**/*.ts",
    ".next-vercel-check/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    "types/**/*.d.ts",
    ".next-preview/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
